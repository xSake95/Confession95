<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CONFESS.EXE - Digital Confessional</title>
    <style>
        @font-face {
            font-family: 'PerfectDOS';
            src: local('Courier New'), local('Courier'), monospace;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: #000;
            color: #c0c0c0;
            font-family: 'Courier New', Courier, monospace;
            font-size: 14px;
            line-height: 1.4;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        .crt::before {
            content: " ";
            display: block;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            background-size: 100% 2px, 3px 100%;
            pointer-events: none;
            z-index: 9999;
        }
        
        .crt::after {
            content: " ";
            display: block;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
            background: rgba(18, 16, 16, 0.1);
            opacity: 0;
            pointer-events: none;
            z-index: 9999;
            animation: flicker 0.15s infinite;
        }
        
        @keyframes flicker {
            0% { opacity: 0.027; }
            5% { opacity: 0.048; }
            10% { opacity: 0.021; }
            15% { opacity: 0.089; }
            20% { opacity: 0.019; }
            25% { opacity: 0.083; }
            30% { opacity: 0.021; }
            35% { opacity: 0.087; }
            40% { opacity: 0.026; }
            45% { opacity: 0.084; }
            50% { opacity: 0.015; }
            55% { opacity: 0.067; }
            60% { opacity: 0.062; }
            65% { opacity: 0.013; }
            70% { opacity: 0.073; }
            75% { opacity: 0.018; }
            80% { opacity: 0.099; }
            85% { opacity: 0.021; }
            90% { opacity: 0.04; }
            95% { opacity: 0.066; }
            100% { opacity: 0.028; }
        }
        
        #startup {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: #000080;
            color: #fff;
            padding: 20px;
        }
        
        .bios-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .bios-header h1 {
            font-size: 24px;
            font-weight: normal;
            letter-spacing: 2px;
            margin-bottom: 10px;
        }
        
        .bios-header p {
            font-size: 12px;
            color: #c0c0c0;
        }
        
        .diagnostics {
            width: 100%;
            max-width: 600px;
            background: #000;
            border: 2px solid #c0c0c0;
            padding: 20px;
            margin-bottom: 30px;
            font-size: 12px;
            line-height: 1.8;
        }
        
        .diagnostics .line {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }
        
        .diagnostics .status {
            color: #0f0;
        }
        
        .diagnostics .status.error {
            color: #f00;
        }
        
        .diagnostics .status.warn {
            color: #ff0;
        }
        
        .progress-bar {
            width: 100%;
            height: 20px;
            border: 1px solid #c0c0c0;
            background: #000;
            margin: 20px 0;
            position: relative;
        }
        
        .progress-fill {
            height: 100%;
            background: #0f0;
            width: 0%;
            transition: width 0.1s linear;
        }
        
        .enter-btn {
            background: #c0c0c0;
            color: #000;
            border: 3px outset #fff;
            padding: 15px 40px;
            font-family: 'Courier New', monospace;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        .enter-btn:hover {
            background: #fff;
        }
        
        .enter-btn:active {
            border: 3px inset #808080;
        }
        
        .enter-btn:disabled {
            background: #808080;
            color: #404040;
            cursor: not-allowed;
            border: 3px outset #808080;
        }
        
        #main-menu {
            display: none;
            min-height: 100vh;
            background: #008080;
            padding: 40px 20px;
        }
        
        .menu-container {
            max-width: 600px;
            margin: 0 auto;
            background: #c0c0c0;
            border: 3px outset #fff;
            box-shadow: 5px 5px 0 rgba(0,0,0,0.5);
        }
        
        .menu-title-bar {
            background: linear-gradient(90deg, #000080, #1084d0);
            color: #fff;
            padding: 3px 8px;
            font-size: 12px;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .menu-title-bar .buttons {
            display: flex;
            gap: 2px;
        }
        
        .win-btn {
            width: 16px;
            height: 14px;
            background: #c0c0c0;
            border: 2px outset #fff;
            font-size: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }
        
        .menu-content {
            padding: 30px;
            background: #c0c0c0;
        }
        
        .app-header {
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px groove #fff;
        }
        
        .app-header h2 {
            font-size: 28px;
            color: #000;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 10px;
        }
        
        .app-header .subtitle {
            font-size: 11px;
            color: #404040;
        }
        
        .menu-options {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        
        .menu-btn {
            background: #c0c0c0;
            border: 3px outset #fff;
            padding: 15px 20px;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            text-align: left;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 15px;
            color: #000;
        }
        
        .menu-btn:hover {
            background: #000080;
            color: #fff;
        }
        
        .menu-btn:active {
            border: 3px inset #808080;
        }
        
        .menu-btn .icon {
            width: 32px;
            height: 32px;
            background: #808080;
            border: 2px inset #c0c0c0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }
        
        .content-screen {
            display: none;
            min-height: 100vh;
            background: #008080;
            padding: 20px;
        }
        
        .window {
            max-width: 700px;
            margin: 0 auto;
            background: #c0c0c0;
            border: 3px outset #fff;
            box-shadow: 5px 5px 0 rgba(0,0,0,0.5);
        }
        
        .window-content {
            padding: 20px;
            background: #fff;
            color: #000;
        }
        
        .back-btn {
            background: #c0c0c0;
            border: 3px outset #fff;
            padding: 8px 16px;
            font-family: 'Courier New', monospace;
            font-size: 12px;
            cursor: pointer;
            margin-bottom: 15px;
            color: #000;
        }
        
        .back-btn:hover {
            background: #000080;
            color: #fff;
        }
        
        .sins-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 10px;
            margin-top: 20px;
        }
        
        .sin-item {
            background: #c0c0c0;
            border: 3px outset #fff;
            padding: 15px;
            cursor: pointer;
            text-align: center;
            font-weight: bold;
            color: #000;
            transition: all 0.1s;
        }
        
        .sin-item:hover {
            background: #000080;
            color: #fff;
            transform: translate(-2px, -2px);
            box-shadow: 4px 4px 0 rgba(0,0,0,0.3);
        }
        
        .sin-item.selected {
            background: #800000;
            color: #fff;
            border: 3px inset #808080;
        }
        
        .confession-area {
            margin-top: 20px;
            padding: 20px;
            background: #000;
            color: #0f0;
            border: 3px inset #808080;
            font-family: 'Courier New', monospace;
        }
        
        .verse-display {
            background: #000080;
            color: #fff;
            padding: 15px;
            margin-bottom: 20px;
            border: 2px inset #c0c0c0;
            font-style: italic;
            line-height: 1.6;
        }
        
        .verse-reference {
            text-align: right;
            font-size: 12px;
            color: #ff0;
            margin-top: 10px;
            font-style: normal;
        }
        
        .confession-prompt {
            color: #0f0;
            margin-bottom: 10px;
            font-size: 12px;
        }
        
        .confession-input, .journal-input {
            width: 100%;
            min-height: 150px;
            background: #000;
            color: #0f0;
            border: none;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            resize: vertical;
            padding: 10px;
            line-height: 1.6;
        }
        
        .confession-input:focus, .journal-input:focus {
            outline: 1px solid #0f0;
        }
        
        .journal-input {
            min-height: 300px;
        }
        
        .save-btn {
            background: #c0c0c0;
            border: 3px outset #fff;
            padding: 10px 30px;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            cursor: pointer;
            margin-top: 15px;
            color: #000;
            font-weight: bold;
        }
        
        .save-btn:hover {
            background: #0f0;
        }
        
        .save-btn:active {
            border: 3px inset #808080;
        }
        
        .saved-list, .journal-list {
            max-height: 400px;
            overflow-y: auto;
            border: 2px inset #c0c0c0;
            background: #fff;
        }
        
        .saved-item, .journal-item {
            padding: 15px;
            border-bottom: 1px solid #808080;
            background: #fff;
        }
        
        .saved-item:nth-child(even), .journal-item:nth-child(even) {
            background: #f0f0f0;
        }
        
        .saved-header, .journal-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 12px;
            color: #808080;
        }
        
        .saved-sin, .journal-title {
            color: #800000;
            font-weight: bold;
            margin-bottom: 10px;
        }
        
        .saved-text, .journal-text {
            color: #000;
            font-style: italic;
            line-height: 1.5;
            background: #000;
            color: #0f0;
            padding: 10px;
            font-family: 'Courier New', monospace;
        }
        
        .delete-btn {
            background: #800000;
            color: #fff;
            border: 2px outset #ff0000;
            padding: 5px 15px;
            font-family: 'Courier New', monospace;
            font-size: 11px;
            cursor: pointer;
            margin-top: 10px;
        }
        
        .delete-btn:hover {
            background: #ff0000;
        }
        
        .empty-state {
            text-align: center;
            padding: 40px;
            color: #808080;
            font-style: italic;
        }
        
        .about-content {
            text-align: center;
            line-height: 2;
        }
        
        .about-content h3 {
            font-size: 20px;
            margin-bottom: 20px;
            color: #000080;
        }
        
        .about-content .creator {
            font-size: 16px;
            margin: 20px 0;
        }
        
        .about-content .company {
            font-size: 14px;
            color: #800000;
            font-weight: bold;
            margin-bottom: 30px;
        }
        
        .about-content .version {
            font-size: 11px;
            color: #808080;
            margin-top: 30px;
        }
        
        .simple-cross {
            font-size: 48px;
            color: #800000;
            margin: 20px 0;
            line-height: 1;
        }
        
        ::-webkit-scrollbar {
            width: 16px;
        }
        
        ::-webkit-scrollbar-track {
            background: #c0c0c0;
            border-left: 1px solid #808080;
        }
        
        ::-webkit-scrollbar-thumb {
            background: #c0c0c0;
            border: 2px outset #fff;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: #d4d0c8;
        }
        
        .notification {
            position: fixed;
            top: 20px;
            right: -300px;
            background: rgba(192, 192, 192, 0.95);
            border-left: 4px solid #0f0;
            padding: 0;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            z-index: 10000;
            min-width: 250px;
            max-width: 300px;
            transition: right 0.3s ease-out;
            font-family: 'Courier New', monospace;
        }
        
        .notification.show {
            right: 20px;
        }
        
        .notification.error {
            border-left-color: #f00;
        }
        
        .notification-header {
            background: #000080;
            color: #fff;
            padding: 6px 12px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .notification-close {
            cursor: pointer;
            font-size: 14px;
            line-height: 1;
        }
        
        .notification-body {
            padding: 15px;
            color: #000;
            font-size: 13px;
            line-height: 1.5;
        }
        
        .notification-body::before {
            content: "► ";
            color: #0f0;
        }
        
        .notification.error .notification-body::before {
            color: #f00;
        }
        
        .marquee-container {
            background: #000080;
            color: #fff;
            padding: 5px;
            overflow: hidden;
            white-space: nowrap;
            margin-bottom: 20px;
        }
        
        .marquee {
            display: inline-block;
            animation: scroll 20s linear infinite;
        }
        
        @keyframes scroll {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }
        
        .journal-prompt {
            color: #0f0;
            margin-bottom: 10px;
            font-size: 12px;
        }
        
        .journal-title-input {
            width: 100%;
            background: #000;
            color: #0f0;
            border: none;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            padding: 10px;
            margin-bottom: 10px;
            border: 1px solid #333;
        }
        
        .journal-title-input:focus {
            outline: 1px solid #0f0;
            border-color: #0f0;
        }
    </style>
</head>
